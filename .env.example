APP_NAME=MPOnline FAQ Chatbot
ENVIRONMENT=development
API_PREFIX=/api
DEBUG=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/faq_chatbot
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
OTP_EXPIRY_MINUTES=10

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=MPOnline FAQ Chatbot
SMTP_USE_TLS=false
SMTP_USE_SSL=true

LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

VECTOR_STORE_PATH=app/data/faiss.index
VECTOR_METADATA_PATH=app/data/faiss_metadata.json
UPLOAD_DIR=app/uploads
TOP_K_CHUNKS=4
MIN_SIMILARITY_SCORE=0.45
MAX_CHUNK_WORDS=180
CHUNK_OVERLAP_WORDS=40
MAX_CONTEXT_CHARACTERS=8000
TESSERACT_CMD=

ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
